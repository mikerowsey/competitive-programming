{
  "version": 8,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25
  },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },

    {
      "name": "base-debug",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },

    {
      "name": "base-release",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },

    {
      "name": "base-clang-tidy",
      "hidden": true,
      "cacheVariables": {
        "CP_ENABLE_CLANG_TIDY": "ON"
      }
    },

    {
      "name": "base-googletest",
      "hidden": true,
      "cacheVariables": {
        "CP_ENABLE_GOOGLETEST": "ON"
      }
    },

    {
      "name": "base-macos-llvm",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "toolchainFile": "${sourceDir}/cmake/toolchains/macos-llvm.cmake"
    },

    {
      "name": "base-linux-gcc",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "toolchainFile": "${sourceDir}/cmake/toolchains/linux-gcc.cmake"
    },

    {
      "name": "release-macos-llvm",
      "inherits": ["base-macos-llvm", "base-release"]
    },

    {
      "name": "release-linux-gcc",
      "inherits": ["base-linux-gcc", "base-release"]
    },

    {
      "name": "clang-tidy",
      "inherits": ["base-debug", "base-clang-tidy"]
    },

    {
      "name": "debug-googletest",
      "inherits": ["base-debug", "base-googletest"]
    },

    {
      "name": "asan-googletest",
      "inherits": "debug-googletest",
      "cacheVariables": {
        "CP_ENABLE_SANITIZERS": "ON"
      }
    },

    {
      "name": "tsan",
      "inherits": "base-debug",
      "cacheVariables": {
        "CP_ENABLE_THREAD_SANITIZER": "ON"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "release-macos-llvm",
      "configurePreset": "release-macos-llvm"
    },
    {
      "name": "release-linux-gcc",
      "configurePreset": "release-linux-gcc"
    },
    {
      "name": "asan-googletest",
      "configurePreset": "asan-googletest"
    },
    {
      "name": "tsan",
      "configurePreset": "tsan"
    },
    {
      "name": "clang-tidy",
      "configurePreset": "clang-tidy"
    },
    {
      "name": "debug-googletest",
      "configurePreset": "debug-googletest"
    }
  ],

  "testPresets": [
    {
      "name": "asan-googletest",
      "configurePreset": "asan-googletest",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug-googletest",
      "configurePreset": "debug-googletest",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
