{
  "version": 8,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25
  },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },

    {
      "name": "debug-config",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },

    {
      "name": "release-config",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },

    {
      "name": "testing",
      "hidden": true,
      "cacheVariables": {
        "CP_ENABLE_TESTING": "ON"
      }
    },

    {
      "name": "tidy-config",
      "hidden": true,
      "cacheVariables": {
        "CP_ENABLE_CLANG_TIDY": "ON"
      }
    },

    {
      "name": "asan-config",
      "hidden": true,
      "cacheVariables": {
        "CP_ENABLE_SANITIZERS": "ON"
      }
    },

    {
      "name": "tsan-config",
      "hidden": true,
      "cacheVariables": {
        "CP_ENABLE_THREAD_SANITIZER": "ON"
      }
    },

    {
      "name": "debug",
      "inherits": "debug-config"
    },

    {
      "name": "release",
      "inherits": "release-config"
    },

    {
      "name": "test",
      "inherits": ["debug-config", "testing"]
    },

    {
      "name": "asan",
      "inherits": ["debug-config", "testing", "asan-config"]
    },

    {
      "name": "tsan",
      "inherits": ["debug-config", "testing", "tsan-config"]
    },

    {
      "name": "tidy",
      "inherits": ["debug-config", "tidy-config"]
    }
  ],

  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "test",
      "configurePreset": "test"
    },
    {
      "name": "asan",
      "configurePreset": "asan"
    },
    {
      "name": "tsan",
      "configurePreset": "tsan"
    },
    {
      "name": "tidy",
      "configurePreset": "tidy"
    }
  ],

  "testPresets": [
    {
      "name": "test",
      "configurePreset": "test",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "asan",
      "configurePreset": "asan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tsan",
      "configurePreset": "tsan",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
